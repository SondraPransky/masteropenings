# Tests E2E authentifiés — copie ce fichier en `.env` (gitignoré) et renseigne
# un COMPTE DE TEST JETABLE (jamais un vrai compte élève/prof).
# Crée-le une fois via l'app (page « Créer un compte »), puis colle-le ici.
#
#   npm run test:e2e:public   → tests page de login (aucun compte requis)
#   npm run test:e2e          → tout, y compris les tests authentifiés (nécessite ci-dessous)

E2E_EMAIL=compte-de-test@example.com
E2E_PASSWORD=motdepasse-de-test
