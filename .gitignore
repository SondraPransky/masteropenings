node_modules/
.DS_Store
Thumbs.db
*.log
.claude/

# Build Vite (artefact, régénéré par `npm run build`)
/dist/

# Env & secrets (jamais commités)
.env

# Playwright / tests E2E
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
tests/e2e/.auth/

# OTKB (usine locale monorepo) — CODE versionné, DONNÉES et SECRET jamais commités.
# Le corpus (.db 18 Go, CSV 1 Go) reste sur la machine ; le pont le sert en local.
otkb/**/__pycache__/
otkb/data/
*.db
*.sqlite
lichess_db_puzzle.csv
config.local.toml

# OA (analytics d'ouvertures monorepo) — CODE versionné, DONNÉES jamais commitées.
# Le cache d'analyse du worker Supabase vit dans data-oa/ (sqlite local).
oa/**/__pycache__/
data-oa/

# Outillage Claude Code local (skill impeccable) — pas du code de l'app
.github/hooks/
.github/skills/
# Skills d'agents installées au niveau projet (CLI `skills add`) — outillage local
.agents/
skills-lock.json
# État runtime du serveur `impeccable live` (pid/port/token de la machine locale).
# `.impeccable/live/config.json` et `design.json`, eux, sont du config → suivis.
.impeccable/live/server.json

# Manifestes d import en masse (ids des modules crees, propres a chaque run)
import-academie-*.json

# Sauvegardes ecrites avant une suppression par tools/modules-admin.mjs : ce sont
# des lignes Supabase entieres (PGN inclus), donc du contenu duplique et date.
# A garder en local le temps de verifier l arbitrage, pas dans l historique.
tools/backup-*.json
_scratch-*
